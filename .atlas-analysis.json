  "keyFeatures": [
    "Streaming text generation with AI SDK and multi-step tool calling",
    "Chunked streaming TTS with parallel generation and low latency",
    "Audio transcription via Whisper",
    "Barge-in and interruption support for natural conversations",
    "Memory management with configurable history limits",
    "Serial request queue preventing race conditions",
    "Full WebSocket protocol for real-time communication",
    "Video agent support for vision-enabled models"
  ],
